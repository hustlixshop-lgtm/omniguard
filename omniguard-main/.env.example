# OmniGuard Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Supabase (Required) ───────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Edge Functions (server-side, auto-configured in hosted env) ──────
# These are automatically available inside Supabase Edge Functions.
# For local Supabase CLI development, add them to supabase/functions/.env
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Anthropic Claude (primary AI provider)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (optional, for GPT-4o integration)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── GitHub Integration ────────────────────────────────────────────────────────
# GitHub Personal Access Token with repo read scope
# Used by scan-worker to fetch repository files
# Get from: https://github.com/settings/tokens/new
# Required scopes: repo (read), read:org (if scanning org repos)
GITHUB_TOKEN=ghp_...

# GitHub App credentials (optional, for GitHub App integration)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ─── OmniGuard CLI / Git Hooks ────────────────────────────────────────────────
# Your Supabase project's functions URL (same as VITE_SUPABASE_URL + /functions/v1)
OMNIGUARD_URL=https://your-project-id.supabase.co/functions/v1

# An OmniGuard API key generated in the dashboard (Settings → API Keys)
# Prefix: og_live_xxx
OMNIGUARD_API_KEY=

# Minimum severity to block commits (critical, high, medium, low, none)
OMNIGUARD_FAIL_ON=critical

# Allow bypass with justification (true/false)
OMNIGUARD_BYPASS=false

# ─── Local Development (Supabase CLI) ────────────────────────────────────────
# These are used when running `supabase start` locally
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ─── Optional Services ────────────────────────────────────────────────────────
# Slack webhook URL for notifications
SLACK_WEBHOOK_URL=

# SMTP for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourcompany.com
